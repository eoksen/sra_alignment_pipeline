nextflow.enable.dsl=2

// nf-schema drives declarative parameter validation and schema-generated --help
// from nextflow_schema.json (see main.nf: validateParameters()/paramsHelp()).
// Pinned to 2.5.x, which requires Nextflow >=25.04 (this repo pins 25.04.8).
plugins {
    id 'nf-schema@2.5.1'
}

includeConfig 'conf/params.config'
includeConfig 'conf/base.config'

process.scratch = true

// Execution profiles select the container/environment engine used to run
// processes. They are MUTUALLY EXCLUSIVE: no engine is enabled globally, so a
// profile MUST be selected explicitly (e.g. `-profile docker`). Docker remains
// the documented default engine. See README.md and `main.nf --help`.
profiles {
    docker {
        docker.enabled = true
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }
    apptainer {
        apptainer.enabled = true
        apptainer.autoMounts = true
    }
    conda {
        // EXPERIMENTAL — scaffold only. Runtime images are now bioconda-derived
        // biocontainers (quay.io/biocontainers/*), so the packages exist on Conda,
        // but the processes do not yet declare per-process `conda` environments, so
        // this profile is not wired up for real runs. Use docker/singularity/apptainer;
        // Singularity/Apptainer pull the biocontainer images directly from quay.io.
        conda.enabled = true
    }
    podman {
        podman.enabled = true
    }
}

report {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_report.html"
}

timeline {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_timeline.html"
}

trace {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_trace.txt"
}
