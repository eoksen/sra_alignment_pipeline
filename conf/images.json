{
  "defaults": {
    "registry": "docker.io",
    "namespace": "eoksen",
    "publish_platforms": [
      "linux/amd64",
      "linux/arm64"
    ],
    "host_platform_map": {
      "x86_64": "linux/amd64",
      "amd64": "linux/amd64",
      "aarch64": "linux/arm64",
      "arm64": "linux/arm64"
    }
  },
  "images": {
    "aria2": {
      "runtime_name": "aria2-sra-download",
      "version": "1.37.0",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/aria2/Dockerfile",
        "context": "dockerfiles/multiarch/aria2",
        "args": {
          "ARIA2_VERSION": "1.37.0"
        }
      }
    },
    "bcftools": {
      "runtime_name": "bcftools",
      "version": "1.23.1",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/bcftools/Dockerfile",
        "context": "dockerfiles/multiarch/bcftools",
        "args": {
          "BCFTOOLS_VERSION": "1.23.1"
        }
      }
    },
    "biopython": {
      "runtime_name": "biopython-pysam",
      "version": "1.86-pysam0.23.3",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/biopython/Dockerfile",
        "context": "dockerfiles/multiarch/biopython",
        "args": {
          "PYTHON_IMAGE": "python:3.13-slim-bookworm",
          "BIOPYTHON_VERSION": "1.86",
          "PYSAM_VERSION": "0.23.3"
        }
      }
    },
    "bowtie2": {
      "runtime_name": "bowtie2",
      "version": "2.5.5",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/bowtie2/Dockerfile",
        "context": "dockerfiles/multiarch/bowtie2",
        "args": {
          "BOWTIE2_VERSION": "2.5.5"
        }
      }
    },
    "fastp": {
      "runtime_name": "fastp",
      "version": "1.3.0",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/fastp/Dockerfile",
        "context": "dockerfiles/multiarch/fastp",
        "args": {
          "FASTP_VERSION": "v1.3.0",
          "LIBISAL_VERSION": "v2.31.1",
          "LIBDEFLATE_VERSION": "v1.25"
        }
      }
    },
    "pigz": {
      "runtime_name": "pigz",
      "version": "2.8",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/pigz/Dockerfile",
        "context": "dockerfiles/multiarch/pigz",
        "args": {
          "PIGZ_VERSION": "2.8-1"
        }
      }
    },
    "qualimap": {
      "runtime_name": "qualimap",
      "version": "2.3",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/qualimap/Dockerfile",
        "context": "dockerfiles/multiarch/qualimap",
        "args": {
          "QUALIMAP_VERSION": "2.3"
        }
      }
    },
    "samtools": {
      "runtime_name": "samtools",
      "version": "1.23.1",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/samtools/Dockerfile",
        "context": "dockerfiles/multiarch/samtools",
        "args": {
          "SAMTOOLS_VERSION": "1.23.1"
        }
      }
    },
    "sra_parser": {
      "runtime_name": "sra-parser",
      "version": "1.1.0",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/sra-parser/Dockerfile",
        "context": "dockerfiles/multiarch/sra-parser",
        "args": {
          "PYTHON_IMAGE": "python:3.13-slim-bookworm",
          "REQUESTS_VERSION": "2.32.3",
          "BEAUTIFULSOUP4_VERSION": "4.12.3",
          "LXML_VERSION": "5.3.0",
          "HTML5LIB_VERSION": "1.1"
        }
      }
    },
    "sra_tools": {
      "runtime_name": "sra-tools",
      "version": "3.2.1",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/sra-tools/Dockerfile",
        "context": "dockerfiles/multiarch/sra-tools",
        "args": {
          "SRA_TOOLS_VERSION": "3.2.1"
        }
      }
    }
  }
}
