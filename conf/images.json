{
  "defaults": {
    "registry": "quay.io",
    "namespace": "biocontainers",
    "publish_platforms": [
      "linux/amd64",
      "linux/arm64"
    ],
    "host_platform_map": {
      "x86_64": "linux/amd64",
      "amd64": "linux/amd64",
      "aarch64": "linux/arm64",
      "arm64": "linux/arm64"
    }
  },
  "images": {
    "aria2": {
      "runtime_name": "aria2-sra-download",
      "version": "1.37.0",
      "registry": "docker.io",
      "namespace": "eoksen",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/aria2/Dockerfile",
        "context": "dockerfiles/multiarch/aria2",
        "args": {
          "ARIA2_VERSION": "1.37.0"
        }
      }
    },
    "bcftools": {
      "runtime_name": "bcftools",
      "version": "1.23.1--hb2cee57_0",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/bcftools/Dockerfile",
        "context": "dockerfiles/multiarch/bcftools",
        "args": {
          "BCFTOOLS_VERSION": "1.23.1"
        }
      }
    },
    "biopython": {
      "runtime_name": "mulled-v2-3a59640f3fe1ed11819984087d31d68600200c3f",
      "version": "185a25ca79923df85b58f42deb48f5ac4481e91f-0"
    },
    "bowtie2": {
      "runtime_name": "bowtie2",
      "version": "2.5.5--ha27dd3b_0",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/bowtie2/Dockerfile",
        "context": "dockerfiles/multiarch/bowtie2",
        "args": {
          "BOWTIE2_VERSION": "2.5.5"
        }
      }
    },
    "fastp": {
      "runtime_name": "fastp",
      "version": "1.3.0--h43da1c4_0",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/fastp/Dockerfile",
        "context": "dockerfiles/multiarch/fastp",
        "args": {
          "FASTP_VERSION": "v1.3.0",
          "LIBISAL_VERSION": "v2.31.1",
          "LIBDEFLATE_VERSION": "v1.25"
        }
      }
    },
    "pigz": {
      "runtime_name": "pigz",
      "version": "2.8",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/pigz/Dockerfile",
        "context": "dockerfiles/multiarch/pigz",
        "args": {
          "PIGZ_VERSION": "2.8-1"
        }
      }
    },
    "qualimap": {
      "runtime_name": "qualimap",
      "version": "2.3--hdfd78af_0",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/qualimap/Dockerfile",
        "context": "dockerfiles/multiarch/qualimap",
        "args": {
          "QUALIMAP_VERSION": "2.3"
        }
      }
    },
    "samtools": {
      "runtime_name": "samtools",
      "version": "1.23.1--ha83d96e_0",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/samtools/Dockerfile",
        "context": "dockerfiles/multiarch/samtools",
        "args": {
          "SAMTOOLS_VERSION": "1.23.1"
        }
      }
    },
    "sra_parser": {
      "runtime_name": "requests",
      "version": "2.26.0"
    },
    "sra_tools": {
      "runtime_name": "sra-tools",
      "version": "3.2.1--h4304569_1",
      "build": {
        "enabled": true,
        "dockerfile": "dockerfiles/multiarch/sra-tools/Dockerfile",
        "context": "dockerfiles/multiarch/sra-tools",
        "args": {
          "SRA_TOOLS_VERSION": "3.2.1"
        }
      }
    }
  }
}
