/*
 * conf/base.config
 * -----------------
 * nf-core-style resource configuration for every process.
 *
 * Instead of a single global `cpus params.cpus`, each process is tagged with a
 * resource `label` (see nf_scripts/*.nf) and this file maps that label onto
 * sensible cpu/memory/time requests. Requests scale up automatically on retry
 * (`* task.attempt`) so a transient/OOM failure is retried with more RAM.
 *
 * All requests are passed through the plain-Groovy `check_max()` helper so they
 * are capped by the laptop-sane `--max_cpus` / `--max_memory` / `--max_time`
 * params (see conf/params.config). `--cpus` is preserved for back-compat: it is
 * folded into the cpu cap (see check_max below), so `--cpus 1` forces every task
 * to a single core exactly as before.
 *
 * NOTE: check_max() is a plain-Groovy helper and does NOT depend on the
 * nf-schema plugin (which drives parameter validation in main.nf). Keeping
 * resource capping self-contained avoids coupling it to the plugin.
 */

process {

    // ---- default request (applied to any unlabelled process) ----
    cpus   = { check_max( 1     * task.attempt, 'cpus'   ) }
    memory = { check_max( 2.GB  * task.attempt, 'memory' ) }
    time   = { check_max( 1.h   * task.attempt, 'time'   ) }

    // ---- retry on resource/transient exit codes; scale memory on retry ----
    // 104/13x/14x cover common OOM (137=SIGKILL), bus/segfault and SIGTERM codes.
    errorStrategy = { task.exitStatus in [104,134,137,138,139,140,143] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    // ---- labelled resource tiers ----
    withLabel:process_low {
        cpus   = { check_max( 1     * task.attempt, 'cpus'   ) }
        memory = { check_max( 2.GB  * task.attempt, 'memory' ) }
        time   = { check_max( 2.h   * task.attempt, 'time'   ) }
    }
    withLabel:process_medium {
        cpus   = { check_max( 2     * task.attempt, 'cpus'   ) }
        memory = { check_max( 4.GB  * task.attempt, 'memory' ) }
        time   = { check_max( 4.h   * task.attempt, 'time'   ) }
    }
    withLabel:process_high {
        cpus   = { check_max( 4     * task.attempt, 'cpus'   ) }
        memory = { check_max( 8.GB  * task.attempt, 'memory' ) }
        time   = { check_max( 8.h   * task.attempt, 'time'   ) }
    }
    withLabel:process_high_memory {
        // bowtie2-build + bowtie2 align is the memory hog (scales with genome size).
        cpus   = { check_max( 4     * task.attempt, 'cpus'   ) }
        memory = { check_max( 12.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h   * task.attempt, 'time'   ) }
    }

    // download_fastq intentionally keeps `errorStrategy 'ignore'` (defined in the
    // module): an ENA FTP miss is expected and must fall through to the
    // fasterq-dump path, not fail the run. withName has the highest precedence,
    // so this guarantees the ignore semantics regardless of directive-precedence.
    withName:download_fastq {
        errorStrategy = 'ignore'
    }
}

/*
 * check_max()
 * -----------
 * nf-core's plain-Groovy resource capper. Given a requested resource and its
 * type, return the request bounded by the configured maximum:
 *   - 'memory' capped at params.max_memory
 *   - 'time'   capped at params.max_time
 *   - 'cpus'   capped at BOTH params.max_cpus and params.cpus (--cpus back-compat)
 * On any parse error it logs and returns the original request unchanged.
 */
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "### WARNING ###   Max memory '${params.max_memory}' is not valid! Using default value: ${obj}"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "### WARNING ###   Max time '${params.max_time}' is not valid! Using default value: ${obj}"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            // Cap by --max_cpus and, for back-compat, by --cpus (default 2).
            return Math.min( obj as int, Math.min( params.max_cpus as int, params.cpus as int ) )
        } catch (all) {
            println "### WARNING ###   Max cpus '${params.max_cpus}' / --cpus '${params.cpus}' is not valid! Using default value: ${obj}"
            return obj
        }
    }
}
